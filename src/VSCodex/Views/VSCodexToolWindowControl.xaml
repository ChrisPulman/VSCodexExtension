<UserControl
    x:Class="VSCodex.Views.VSCodexToolWindowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:VSCodex.Views"
    xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    x:Name="Root"
    MinWidth="320"
    MinHeight="360"
    Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
    Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">
    <UserControl.Resources>
        <views:RoleBrushConverter x:Key="RoleBrushConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style x:Key="MessageTextBoxStyle" TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style x:Key="VSCodexComboBoxEditableTextBoxStyle" TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="False" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Margin" Value="0,2,0,8" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton
                                x:Name="DropDownToggle"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClickMode="Press"
                                Focusable="False"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border
                                            x:Name="ToggleBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Path
                                                    x:Name="Arrow"
                                                    Width="8"
                                                    Height="5"
                                                    Margin="0,0,8,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 4 4 L 8 0 Z"
                                                    Fill="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBackgroundBrushKey}}" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBorderBrushKey}}" />
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBackgroundBrushKey}}" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBorderBrushKey}}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledBackgroundBrushKey}}" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledBorderBrushKey}}" />
                                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledTextBrushKey}}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter
                                x:Name="ContentSite"
                                Margin="8,3,26,3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                IsHitTestVisible="False" />
                            <TextBox
                                x:Name="PART_EditableTextBox"
                                Margin="4,3,26,3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                IsReadOnly="{TemplateBinding IsReadOnly}"
                                Style="{StaticResource VSCodexComboBoxEditableTextBoxStyle}"
                                Visibility="Hidden" />
                            <Popup
                                x:Name="Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border
                                        Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxPopupBackgroundBeginBrushKey}}"
                                        BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}"
                                        BorderThickness="1" />
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBackgroundBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedTextBrushKey}}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBorderBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledBackgroundBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledTextBrushKey}}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledBorderBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBackgroundBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedTextBrushKey}}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxFocusedBorderBrushKey}}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledBackgroundBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledTextBrushKey}}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxDisabledBorderBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxPopupBackgroundBeginBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemTextBrushKey}}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemMouseOverBackgroundBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxItemMouseOverTextBrushKey}}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxSelectionBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style
            x:Key="CompactButtonStyle"
            BasedOn="{StaticResource {x:Type Button}}"
            TargetType="Button">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,5,5" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Margin" Value="0,2,0,8" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabBorderBrushKey}}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border
                            x:Name="TabBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1">
                            <ContentPresenter
                                x:Name="HeaderSite"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabHotTextBrushKey}}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabHotBorderBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabSelectedBackgroundBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabSelectedTextBrushKey}}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabSelectedBorderBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabInactiveTextBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabSelectedBackgroundBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabSelectedTextBrushKey}}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.FileTabSelectedBorderBrushKey}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="4" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style x:Key="SectionHeaderTextBlock" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,6" />
        </Style>

        <Style x:Key="FieldLabelTextBlock" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <DataTemplate x:Key="RateLimitTemplate">
            <Grid Margin="0,0,0,7">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontWeight="SemiBold"
                    Text="{Binding Label}" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="1"
                    Opacity="0.86"
                    Text="{Binding Remaining}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Opacity="0.72"
                    Text="{Binding ResetText}" />
                <ProgressBar
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Maximum="100"
                    Minimum="0"
                    Value="{Binding UsagePercent}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="10,7"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Image
                        Width="20"
                        Height="20"
                        Margin="0,0,7,6"
                        VerticalAlignment="Center"
                        Source="/VSCodex;component/Resources/VSCodexIcon-32.png"
                        ToolTip="VSCodex" />
                    <TextBlock
                        Margin="0,0,12,6"
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="VSCodex" />
                    <Button
                        Command="{Binding NewThreadCommand}"
                        Content="New Thread"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="Start a fresh VSCodex thread." />
                    <Button
                        Command="{Binding ShowSettingsCommand}"
                        Content="Settings"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="Open VSCodex model, MCP, memory, and execution settings." />
                </WrapPanel>

                <TextBlock
                    Grid.Row="1"
                    Margin="0,3,0,4"
                    Opacity="0.72"
                    Text="{Binding Status}"
                    TextTrimming="CharacterEllipsis" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Margin="0,1,8,0"
                        VerticalAlignment="Top"
                        FontWeight="SemiBold"
                        Text="Rate limits remaining" />
                    <ItemsControl
                        Grid.Column="1"
                        MinWidth="160"
                        ItemTemplate="{StaticResource RateLimitTemplate}"
                        ItemsSource="{Binding RateLimits}"
                        ToolTip="{Binding RateLimitUpdatedAt}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <DockPanel>
                <Border
                    Padding="12"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Conversation" />
                        <TextBlock
                            Margin="0,3,0,8"
                            Opacity="0.72"
                            Text="Use # for selected code and references, / for focused commands, @ for files, and MCP tools from the controls pane." />
                        <WrapPanel>
                            <Button
                                Command="{Binding ReviewSelectionCommand}"
                                Content="Review selection"
                                Style="{StaticResource CompactButtonStyle}"
                                ToolTip="Prepare a focused code review prompt from the current selection." />
                            <Button
                                Command="{Binding DebugSelectionCommand}"
                                Content="Fix active errors"
                                Style="{StaticResource CompactButtonStyle}"
                                ToolTip="Prepare a VSCodex debugging prompt using the active exception or error context." />
                            <Button
                                Command="{Binding CreateTestForSelectionCommand}"
                                Content="Write tests"
                                Style="{StaticResource CompactButtonStyle}"
                                ToolTip="Prepare a test generation prompt from the current selection." />
                            <Button
                                Command="{Binding CreatePlanCommand}"
                                Content="Plan work"
                                Style="{StaticResource CompactButtonStyle}"
                                ToolTip="Create a multi-agent implementation plan." />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <ListBox BorderThickness="0" ItemsSource="{Binding Messages}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="8,6"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="3">
                                <StackPanel>
                                    <DockPanel LastChildFill="True">
                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Margin="0,3,6,0"
                                            DockPanel.Dock="Left"
                                            Fill="{Binding Role, Converter={StaticResource RoleBrushConverter}}" />
                                        <TextBlock
                                            DockPanel.Dock="Left"
                                            FontWeight="SemiBold"
                                            Text="{Binding Role}" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            Opacity="0.65"
                                            Text="{Binding Timestamp}"
                                            TextAlignment="Right" />
                                    </DockPanel>
                                    <TextBox
                                        Margin="0,6,0,0"
                                        BorderThickness="0"
                                        IsReadOnly="True"
                                        Style="{StaticResource MessageTextBoxStyle}"
                                        Text="{Binding Content}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <DockPanel
                Width="430"
                MinWidth="300"
                MaxWidth="{Binding ActualWidth, ElementName=Root}"
                HorizontalAlignment="Right"
                Panel.ZIndex="10"
                Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                Visibility="{Binding IsSettingsPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border
                    Padding="8,6"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="VSCodex controls" />
                        <Button
                            Grid.Column="1"
                            Margin="0"
                            Click="OnCloseSettingsPanelClick"
                            Content="Close"
                            Style="{StaticResource CompactButtonStyle}" />
                    </Grid>
                </Border>
                <TabControl
                    Margin="0"
                    IsHitTestVisible="{Binding CanEditSettings}"
                    SelectedIndex="{Binding SelectedToolTabIndex, Mode=TwoWay}">
                    <TabItem Header="Settings">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <TextBlock Style="{StaticResource SectionHeaderTextBlock}" Text="Setup" />
                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontWeight="SemiBold"
                                    Text="{Binding CodexSetupSummary}" />
                                <ItemsControl ItemsSource="{Binding Prerequisites}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,0,0,6"
                                                Padding="8"
                                                BorderThickness="1"
                                                CornerRadius="3">
                                                <StackPanel>
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock
                                                            DockPanel.Dock="Left"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Name}" />
                                                        <TextBlock
                                                            HorizontalAlignment="Right"
                                                            FontWeight="SemiBold"
                                                            Opacity="0.86"
                                                            Text="{Binding Status}" />
                                                    </DockPanel>
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        Opacity="0.72"
                                                        Text="{Binding Description}" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        Opacity="0.72"
                                                        Text="{Binding Details}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        FontFamily="Consolas"
                                                        Opacity="0.86"
                                                        Text="{Binding InstallCommand}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBox
                                    MinHeight="96"
                                    Margin="0,2,0,8"
                                    IsReadOnly="True"
                                    Text="{Binding CodexSetupInstructions}" />
                                <Button
                                    HorizontalAlignment="Left"
                                    Command="{Binding CheckPrerequisitesCommand}"
                                    Content="Check setup"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="Check Node.js, npm, @openai/codex-sdk, and optional Codex CLI fallback." />

                                <Border Margin="0,8,0,0" BorderThickness="0,1,0,0" />
                                <TextBlock Style="{StaticResource SectionHeaderTextBlock}" Text="Model" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Mode" />
                                <ComboBox ItemsSource="{Binding ModeOptions}" SelectedItem="{Binding Mode}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Primary" />
                                <ComboBox
                                    IsEditable="True"
                                    ItemsSource="{Binding ModelOptions}"
                                    Text="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Failover" />
                                <ComboBox
                                    IsEditable="True"
                                    ItemsSource="{Binding ModelOptions}"
                                    Text="{Binding FailoverModel, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Budget driven model selection" IsChecked="{Binding BudgetDrivenModelSelection}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Budget model" />
                                <ComboBox
                                    IsEditable="True"
                                    ItemsSource="{Binding ModelOptions}"
                                    Text="{Binding BudgetModel, UpdateSourceTrigger=PropertyChanged}" />

                                <Border Margin="0,8,0,0" BorderThickness="0,1,0,0" />
                                <TextBlock Style="{StaticResource SectionHeaderTextBlock}" Text="Execution" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Reasoning" />
                                <ComboBox ItemsSource="{Binding ReasoningOptions}" SelectedItem="{Binding SelectedReasoning}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Verbosity" />
                                <ComboBox ItemsSource="{Binding VerbosityOptions}" SelectedItem="{Binding SelectedVerbosity}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Approval" />
                                <ComboBox ItemsSource="{Binding ApprovalOptions}" SelectedItem="{Binding ApprovalPolicy}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Sandbox" />
                                <ComboBox ItemsSource="{Binding SandboxOptions}" SelectedItem="{Binding SandboxMode}" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Transport" />
                                <ComboBox ItemsSource="{Binding TransportOptions}" SelectedItem="{Binding Transport}" />

                                <Border Margin="0,8,0,0" BorderThickness="0,1,0,0" />
                                <TextBlock Style="{StaticResource SectionHeaderTextBlock}" Text="Rate limits" />
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Opacity="0.72"
                                    Text="{Binding RateLimitUpdatedAt}" />
                                <ItemsControl ItemTemplate="{StaticResource RateLimitTemplate}" ItemsSource="{Binding RateLimits}" />

                                <Border Margin="0,8,0,0" BorderThickness="0,1,0,0" />
                                <TextBlock Style="{StaticResource SectionHeaderTextBlock}" Text="Tool Window" />
                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Input height" />
                                <TextBox AcceptsReturn="False" Text="{Binding InputAreaHeight, UpdateSourceTrigger=LostFocus, StringFormat=F0}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Context">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <GroupBox
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Header="@ files">
                                <ListBox ItemsSource="{Binding FileSuggestions}" MouseDoubleClick="OnReferenceSuggestionDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="6">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding ReferenceKey}" />
                                                <TextBlock Opacity="0.72" Text="{Binding RelativePath}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                            <GroupBox Grid.Row="1" Header="# references">
                                <ListBox ItemsSource="{Binding ContextSuggestions}" MouseDoubleClick="OnReferenceSuggestionDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="6">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding ReferenceKey}" />
                                                <TextBlock Opacity="0.72" Text="{Binding ReferenceKind}" />
                                                <TextBlock Opacity="0.72" Text="{Binding RelativePath}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Skills">
                        <ListBox ItemsSource="{Binding Skills}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="6">
                                        <CheckBox
                                            Content="{Binding Name}"
                                            FontWeight="SemiBold"
                                            IsChecked="{Binding IsEnabled}" />
                                        <TextBlock Opacity="0.72" Text="{Binding Description}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>

                    <TabItem Header="MCP">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <GroupBox
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Header="Servers">
                                <ListBox ItemsSource="{Binding McpServers}" SelectedItem="{Binding SelectedMcpServer}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <CheckBox
                                                    Content="{Binding Name}"
                                                    FontWeight="SemiBold"
                                                    IsChecked="{Binding IsEnabled}" />
                                                <TextBlock
                                                    Opacity="0.72"
                                                    Text="{Binding Command}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <Button
                                                    Command="{Binding DataContext.SelectMcpServerCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Content="List tools"
                                                    Style="{StaticResource CompactButtonStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <GroupBox
                                Grid.Row="1"
                                Margin="0,0,0,8"
                                Header="Tools">
                                <ListBox ItemsSource="{Binding McpToolSuggestions}" SelectedItem="{Binding SelectedMcpTool}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                <TextBlock Opacity="0.72" Text="{Binding Description}" />
                                                <Button
                                                    Command="{Binding DataContext.SelectMcpToolCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}"
                                                    Content="Use tool"
                                                    Style="{StaticResource CompactButtonStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>

                            <StackPanel Grid.Row="2">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Opacity="0.76"
                                    Text="{Binding McpInputPrompt}" />
                                <ItemsControl ItemsSource="{Binding McpToolInputFields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayLabel}" />
                                                <TextBlock Opacity="0.72" Text="{Binding Description}" />
                                                <TextBox AcceptsReturn="False" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button
                                    HorizontalAlignment="Left"
                                    Command="{Binding InsertMcpToolCommand}"
                                    Content="Insert MCP tool use"
                                    Style="{StaticResource CompactButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Analytics">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <TextBlock FontWeight="SemiBold" Text="{Binding AnalyticsSummary}" />
                                <TextBlock
                                    Margin="0,6,0,10"
                                    Opacity="0.76"
                                    Text="{Binding AnalyticsRecommendation}" />
                                <WrapPanel>
                                    <Button
                                        Command="{Binding RefreshAnalyticsCommand}"
                                        Content="Refresh analytics"
                                        Style="{StaticResource CompactButtonStyle}" />
                                    <Button
                                        Command="{Binding ApplyRecommendedModelCommand}"
                                        Content="Apply recommendation"
                                        Style="{StaticResource CompactButtonStyle}" />
                                </WrapPanel>

                                <Grid Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Input tokens" />
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.EstimatedInputTokens}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Output tokens" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.EstimatedOutputTokens}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Primary cost" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.PrimaryEstimatedCost, StringFormat={}{0:C4}}" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Budget cost" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.BudgetEstimatedCost, StringFormat={}{0:C4}}" />
                                    <TextBlock
                                        Grid.Row="4"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Savings" />
                                    <TextBlock
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.EstimatedSavingsPercent, StringFormat={}{0:F0}%}" />
                                    <TextBlock
                                        Grid.Row="5"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Complexity" />
                                    <TextBlock
                                        Grid.Row="5"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.Complexity}" />
                                    <TextBlock
                                        Grid.Row="6"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        FontWeight="SemiBold"
                                        Text="Recommended" />
                                    <TextBlock
                                        Grid.Row="6"
                                        Grid.Column="1"
                                        Text="{Binding ModelEstimate.RecommendedModel}" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Memory">
                        <DockPanel Margin="8">
                            <WrapPanel DockPanel.Dock="Top">
                                <Button
                                    Command="{Binding AddUserMemoryCommand}"
                                    Content="Save user memory"
                                    Style="{StaticResource CompactButtonStyle}" />
                                <Button
                                    Command="{Binding AddWorkspaceMemoryCommand}"
                                    Content="Save workspace memory"
                                    Style="{StaticResource CompactButtonStyle}" />
                            </WrapPanel>
                            <ListBox ItemsSource="{Binding Memories}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Scope}" />
                                            <TextBlock Text="{Binding Text}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="Agents">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <GroupBox
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Header="Roles">
                                <ListBox ItemsSource="{Binding AgentRoles}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="6">
                                                <CheckBox
                                                    Content="{Binding Name}"
                                                    FontWeight="SemiBold"
                                                    IsChecked="{Binding IsEnabled}" />
                                                <TextBlock Text="{Binding Role}" />
                                                <TextBlock Opacity="0.72" Text="{Binding Instructions}" />
                                                <TextBlock Style="{StaticResource FieldLabelTextBlock}" Text="Model" />
                                                <ComboBox
                                                    IsEditable="True"
                                                    ItemsSource="{Binding DataContext.ModelOptions, ElementName=Root}"
                                                    Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                                                <ComboBox ItemsSource="{Binding DataContext.AgentModelSelectionModeOptions, ElementName=Root}" SelectedItem="{Binding ModelSelectionMode}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                            <GroupBox Grid.Row="1" Header="Plan">
                                <ListBox ItemsSource="{Binding OrchestrationSections}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="6">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                <TextBlock Text="{Binding AssignedAgent}" />
                                                <TextBlock Opacity="0.72" Text="{Binding Status}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </GroupBox>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Attachments">
                        <DockPanel Margin="8">
                            <WrapPanel DockPanel.Dock="Top">
                                <Button
                                    Command="{Binding AddImageAttachmentCommand}"
                                    Content="Attach files"
                                    Style="{StaticResource CompactButtonStyle}" />
                                <Button
                                    Command="{Binding ClearAttachmentsCommand}"
                                    Content="Clear attachments"
                                    Style="{StaticResource CompactButtonStyle}" />
                            </WrapPanel>
                            <ListBox ItemsSource="{Binding Attachments}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="6">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <TextBlock Opacity="0.72" Text="{Binding Kind}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Grid>

        <Border
            Grid.Row="2"
            Margin="8"
            Padding="8"
            BorderThickness="1"
            CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,4">
                    <Button
                        Command="{Binding RefreshCommand}"
                        Content="+ Reference"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="Refresh workspace references, then use @ files or # references." />
                    <Button
                        Command="{Binding ExplainSelectionCommand}"
                        Content="Explain"
                        Style="{StaticResource CompactButtonStyle}" />
                    <Button
                        Command="{Binding FixSelectionCommand}"
                        Content="Fix"
                        Style="{StaticResource CompactButtonStyle}" />
                    <Button
                        Command="{Binding ReviewSelectionCommand}"
                        Content="Review"
                        Style="{StaticResource CompactButtonStyle}" />
                    <Button
                        Command="{Binding OptimizeSelectionCommand}"
                        Content="Optimize"
                        Style="{StaticResource CompactButtonStyle}" />
                    <Button
                        Command="{Binding GenerateDocsCommand}"
                        Content="Docs"
                        Style="{StaticResource CompactButtonStyle}" />
                </WrapPanel>

                <TextBox
                    x:Name="PromptTextBox"
                    Grid.Row="1"
                    Height="{Binding InputAreaHeight}"
                    MinHeight="80"
                    MaxHeight="420"
                    AllowDrop="True"
                    Drop="OnPromptDrop"
                    PreviewDragOver="OnPromptPreviewDragOver"
                    PreviewKeyDown="OnPromptPreviewKeyDown"
                    Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Ask VSCodex. Ctrl+Enter runs, Esc cancels. Use /MCP, /debug, /test, /plan, @filename, or #selection." />

                <Popup
                    x:Name="PromptSuggestionPopup"
                    Grid.Row="1"
                    AllowsTransparency="True"
                    IsOpen="{Binding IsPromptSuggestionOpen, Mode=TwoWay}"
                    Placement="Top"
                    PlacementTarget="{Binding ElementName=PromptTextBox}"
                    StaysOpen="True">
                    <Border
                        Width="{Binding ActualWidth, ElementName=PromptTextBox}"
                        MaxHeight="260"
                        Padding="1"
                        Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxPopupBackgroundBeginBrushKey}}"
                        BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                        BorderThickness="1">
                        <ListBox
                            x:Name="PromptSuggestionList"
                            MaxHeight="250"
                            ItemsSource="{Binding PromptSuggestions}"
                            KeyboardNavigation.DirectionalNavigation="Contained"
                            MouseDoubleClick="OnPromptSuggestionDoubleClick"
                            SelectedItem="{Binding SelectedPromptSuggestion, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontWeight="SemiBold"
                                            Opacity="0.78"
                                            Text="{Binding Kind}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding DisplayText}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Text="{Binding Detail}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <WrapPanel
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,4,6"
                        VerticalAlignment="Center"
                        Opacity="0.76"
                        Text="Agent" />
                    <ComboBox
                        Width="140"
                        MinWidth="118"
                        IsHitTestVisible="{Binding CanEditSettings}"
                        ItemsSource="{Binding ModeOptions}"
                        SelectedItem="{Binding Mode}"
                        ToolTip="VSCodex mode for this request." />
                    <TextBlock
                        Margin="4,0,4,6"
                        VerticalAlignment="Center"
                        Opacity="0.76"
                        Text="Model" />
                    <ComboBox
                        Width="180"
                        MinWidth="118"
                        IsEditable="True"
                        IsHitTestVisible="{Binding CanEditSettings}"
                        ItemsSource="{Binding ModelOptions}"
                        Text="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Primary model for this request." />
                    <Button
                        MinWidth="82"
                        VerticalAlignment="Center"
                        Command="{Binding RunCommand}"
                        Content="Run"
                        ToolTip="Run VSCodex with the current prompt. Shortcut: Ctrl+Enter." />
                    <Button
                        MinWidth="82"
                        VerticalAlignment="Center"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        ToolTip="Cancel the running VSCodex request. Shortcut: Esc." />
                </WrapPanel>
            </Grid>
        </Border>

        <StatusBar Grid.Row="3">
            <StatusBarItem Content="{Binding Status}" />
            <Separator />
            <StatusBarItem Content="Thread:" />
            <StatusBarItem Content="{Binding ThreadId}" />
            <Separator />
            <StatusBarItem Content="{Binding RateLimitUpdatedAt}" />
        </StatusBar>
    </Grid>
</UserControl>
