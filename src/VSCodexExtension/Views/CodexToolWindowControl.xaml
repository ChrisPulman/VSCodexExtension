<UserControl x:Class="VSCodexExtension.Views.CodexToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:VSCodexExtension.Views">
    <UserControl.Resources>
        <views:RoleBrushConverter x:Key="RoleBrushConverter" />
        <Style TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="180" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="8" BorderBrush="#333" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Mode" Margin="0,4,4,0" /><ComboBox Width="90" ItemsSource="{Binding ModeOptions}" SelectedItem="{Binding Mode}" Margin="0,0,8,0" />
                <TextBlock Text="Model" Margin="0,4,4,0" /><ComboBox Width="130" IsEditable="True" ItemsSource="{Binding ModelOptions}" Text="{Binding SelectedModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                <TextBlock Text="Reasoning" Margin="0,4,4,0" /><ComboBox Width="90" ItemsSource="{Binding ReasoningOptions}" SelectedItem="{Binding SelectedReasoning}" Margin="0,0,8,0" />
                <TextBlock Text="Verbosity" Margin="0,4,4,0" /><ComboBox Width="90" ItemsSource="{Binding VerbosityOptions}" SelectedItem="{Binding SelectedVerbosity}" Margin="0,0,8,0" />
                <TextBlock Text="Approval" Margin="0,4,4,0" /><ComboBox Width="110" ItemsSource="{Binding ApprovalOptions}" SelectedItem="{Binding ApprovalPolicy}" Margin="0,0,8,0" />
                <TextBlock Text="Sandbox" Margin="0,4,4,0" /><ComboBox Width="140" ItemsSource="{Binding SandboxOptions}" SelectedItem="{Binding SandboxMode}" Margin="0,0,8,0" />
                <TextBlock Text="Transport" Margin="0,4,4,0" /><ComboBox Width="110" ItemsSource="{Binding TransportOptions}" SelectedItem="{Binding Transport}" Margin="0,0,8,0" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            </WrapPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="3*" /><ColumnDefinition Width="340" /></Grid.ColumnDefinitions>
            <ListBox Grid.Column="0" ItemsSource="{Binding Messages}" BorderThickness="0">
                <ListBox.ItemTemplate><DataTemplate><Border Margin="6" Padding="8" CornerRadius="6" BorderThickness="1" BorderBrush="#444"><StackPanel><DockPanel><Ellipse Width="10" Height="10" Fill="{Binding Role, Converter={StaticResource RoleBrushConverter}}" DockPanel.Dock="Left" Margin="0,0,6,0" /><TextBlock Text="{Binding Role}" FontWeight="Bold" /><TextBlock Text="{Binding Timestamp}" Margin="8,0,0,0" Opacity="0.65" /></DockPanel><TextBox Text="{Binding Content}" IsReadOnly="True" BorderThickness="0" Background="Transparent" Margin="0,6,0,0" /></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <TabControl Grid.Column="1">
                <TabItem Header="Skills"><ListBox ItemsSource="{Binding Skills}"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="4"><CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Name}" FontWeight="Bold" /><TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.7" /></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
                <TabItem Header="MCP"><ListBox ItemsSource="{Binding McpServers}"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="4"><CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Name}" FontWeight="Bold" /><TextBlock Text="{Binding Command}" /><TextBlock Text="{Binding Health}" Opacity="0.7" /></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
                <TabItem Header="Memory"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4"><Button Content="Save user memory from prompt" Command="{Binding AddUserMemoryCommand}" Margin="0,0,4,0" /><Button Content="Save workspace memory" Command="{Binding AddWorkspaceMemoryCommand}" /></StackPanel><ListBox ItemsSource="{Binding Memories}"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="4"><TextBlock Text="{Binding Scope}" FontWeight="Bold" /><TextBlock Text="{Binding Text}" TextWrapping="Wrap" /></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></DockPanel></TabItem>
                <TabItem Header="@files"><ListBox ItemsSource="{Binding FileSuggestions}"><ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding RelativePath}" Margin="4" /></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
                <TabItem Header="Images"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><Button Content="Attach image" Command="{Binding AddImageAttachmentCommand}" Margin="0,0,4,0" /><Button Content="Clear attachments" Command="{Binding ClearAttachmentsCommand}" /></StackPanel><ListBox ItemsSource="{Binding Attachments}" DisplayMemberPath="DisplayName" /></DockPanel></TabItem>
            </TabControl>
        </Grid>
        <Grid Grid.Row="2" Margin="8">
            <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBox Grid.Row="0" Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}" ToolTip="Ask Codex. Use @filename to attach solution context." />
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"><Button Content="Run" Width="92" Command="{Binding RunCommand}" Margin="0,0,8,0" /><Button Content="Cancel" Width="92" Command="{Binding CancelCommand}" /></StackPanel>
        </Grid>
        <StatusBar Grid.Row="3"><StatusBarItem Content="{Binding Status}" /><Separator /><StatusBarItem Content="Thread:" /><StatusBarItem Content="{Binding ThreadId}" /></StatusBar>
    </Grid>
</UserControl>
